rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Match block for users collection
    match /users/{username} {
      allow read, write: if username is string && username.size() >= 3 && username.size() <= 128;
    }
  }
}
